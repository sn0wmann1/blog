---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const posts = await getCollection("blog");
posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="blog">
  <h1 class="page-title">blog</h1>
  <p class="page-desc">notes on configs, keyboard hacking, project builds</p>

  <ul class="posts">
    {posts.map((post) => (
      <li>
        <article>
          <time datetime={post.data.pubDate.toISOString()}>
            {post.data.pubDate.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}
          </time>
          <h2><a href={`${import.meta.env.BASE_URL}/${post.id}/`}>{post.data.title}</a></h2>
          <p>{post.data.description}</p>
        </article>
      </li>
    ))}
  </ul>

  <footer>
    <a href="https://github.com/sn0wmann1">github</a>
    <a href="https://sn0wmann1.github.io/">landing</a>
  </footer>
</BaseLayout>

<style>
  .page-title { font-size: 1.8rem; font-weight: 700; margin: 1rem 0 0.2rem; }
  .page-desc { color: #888; margin-bottom: 1.5rem; font-size: 0.9rem; }
  .posts { list-style: none; padding: 0; }
  .posts li { margin-bottom: 1.5rem; }
  time { font-size: 0.85rem; color: #666; }
  h2 { margin: 0.3rem 0; font-size: 1.1rem; }
  h2 a { color: #58a6ff; text-decoration: none; }
  h2 a:hover { text-decoration: underline; }
  p { margin: 0; color: #888; font-size: 0.9rem; }
  footer { margin-top: 3rem; padding: 1rem 0; display: flex; gap: 1rem; }
  footer a { color: #58a6ff; }
</style>
